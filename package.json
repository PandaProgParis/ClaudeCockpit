{
  "name": "claude-cockpit",
  "version": "0.1.0",
  "description": "Personal Claude Code session history viewer",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n server,vite -c cyan,green \"tsx watch src/server/index.ts\" \"vite\"",
    "build": "vite build",
    "start": "npm run build && tsx src/server/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build:extension": "rm -rf dist/extension && mkdir -p dist/extension && cp -r chrome-extension/* dist/extension/",
    "package:extension": "npm run build:extension && cd dist && zip -r claudecockpit-extension.zip extension/ && echo 'Extension packaged: dist/claudecockpit-extension.zip'",
    "electron:dev": "concurrently -k -n server,vite,electron -c cyan,green,yellow \"tsx watch src/server/index.ts\" \"vite\" \"wait-on http://localhost:3001 && wait-on http://localhost:5200 && electron .\"",
    "electron:build": "vite build && node -e \"const b=require('esbuild').buildSync;b({entryPoints:['electron/main.ts'],bundle:true,platform:'node',format:'cjs',outfile:'dist/electron/main.js',external:['electron']});b({entryPoints:['src/server/index.ts'],bundle:true,platform:'node',format:'cjs',outfile:'dist/server/index.js',external:['express','fsevents']})\"",
    "electron:dist": "npm run electron:build && electron-builder"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "express": "^5.0.0",
    "lucide-react": "^0.400.0",
    "open": "^10.0.0",
    "recharts": "^3.8.1"
  }
}
